# Express API Server Port
PORT=5000
NODE_ENV=development

# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/quickbite

# JWT Encryption Key
JWT_SECRET=super-secret-key-quickbite-2026-production-ready

# Client Frontend Application URL
CLIENT_URL=http://localhost:3000

# Twilio SMS Service Configuration (Get these in Twilio Console)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Nodemailer + Gmail App Password Configuration
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# Google OAuth 2.0 Client credentials (Optional - for real Google sign-in)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
